{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test:e2e": "powershell -ExecutionPolicy Bypass -File ../scripts/run_e2e.ps1",
    "deploy:pages": "npm run build:pages && wrangler pages deploy dist --project-name=masmo",
    "deploy:pages:preview": "npm run build:pages && wrangler pages deploy dist --project-name=masmo --branch=preview"
  },
  "dependencies": {
    "@types/dagre": "^0.7.54",
    "dagre": "^0.8.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250704.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wrangler": "^4.24.0"
  }
}
