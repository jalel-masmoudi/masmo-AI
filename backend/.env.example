# Vultr (primary)
VULTR_API_KEY=
VULTR_MODEL=vultr/llama-3.1-8b-instruct

# OpenRouter (fallback)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/meta-llama/llama-3.1-8b-instruct

# CORS — comma-separated frontend origins for production
CORS_ORIGINS=http://localhost:5173,https://your-pages-project.pages.dev

# Gradium (voice STT/TTS)
GRADIUM_API_KEY=
GRADIUM_VOICE_EN=YTpq7expH9539ERJ
GRADIUM_VOICE_FR=LFZvm12tW_z0xfGo
GRADIUM_VOICE_DE=YTpq7expH9539ERJ
GRADIUM_VOICE_ES=LFZvm12tW_z0xfGo
GRADIUM_VOICE_PT=LFZvm12tW_z0xfGo

# Agent behaviour
# Set to 1 for fast deterministic investigations (no LLM calls) — used by e2e tests
MASMO_HEURISTIC_ONLY=0
# Max seconds to wait per LLM request before falling back
LLM_TIMEOUT_SECONDS=20
